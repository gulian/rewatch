# PostgreSQL — dedicated `rewatch` database
DATABASE_URL="postgresql://rewatch:CHANGEME@localhost:5432/rewatch"

# API
PORT=3010
HOST=127.0.0.1
NODE_ENV=production

# Set to "false" to close self-service signups (existing accounts still work)
REGISTRATION_ENABLED=true

# TMDB — v4 API key (Read Access Token), server-side only
TMDB_API_TOKEN=""
# Language of the base metadata cache (per-user fr/en translations are always fetched)
TMDB_LANGUAGE="en-US"

# Public app URL (used in email links)
APP_URL="http://localhost:5173"

# SMTP — leave SMTP_HOST empty to disable email sending (links are logged instead)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Rewatch <no-reply@example.com>"

# Web Push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
